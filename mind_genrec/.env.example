MIND_GENREC_HOST=0.0.0.0
MIND_GENREC_PORT=8000
MIND_GENREC_RELOAD=false
MIND_GENREC_LOG_LEVEL=info

MIND_GENREC_CACHE_TTL_SECONDS=600
# Redis Cloud: omit username to avoid HELLO negotiation (use redis://:password@host:port)
MIND_GENREC_REDIS_URL=redis://:your_password@your_host:your_port

MIND_GENREC_NEWS_JSONL=/app/artifacts/normalized/news.jsonl
MIND_GENREC_SEMANTIC_DIR=/app/artifacts/semantic_ids
MIND_GENREC_GENERATOR_CKPT=/app/artifacts/generator/best_generator.pt
MIND_GENREC_BASELINE_CKPT=/app/artifacts/baseline/best_baseline.pt
MIND_GENREC_DEVICE=cpu
